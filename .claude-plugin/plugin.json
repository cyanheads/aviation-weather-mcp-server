{
  "name": "aviation-weather-mcp-server",
  "version": "0.1.4",
  "description": "Fetch METARs, TAFs, PIREPs, and SIGMETs/AIRMETs from the NWS Aviation Weather Center via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/aviation-weather-mcp-server#readme",
  "repository": "git+https://github.com/cyanheads/aviation-weather-mcp-server.git",
  "license": "Apache-2.0",
  "mcpServers": {
    "aviation-weather-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@cyanheads/aviation-weather-mcp-server"
      ],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
